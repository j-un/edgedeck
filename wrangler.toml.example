name = "edgedeck"
compatibility_date = "2024-12-01"
main = "src/worker.ts"
workers_dev = false

routes = [
  { pattern = "<your-domain>", custom_domain = true }
]

[assets]
directory = "dist"

[[d1_databases]]
binding = "DB"
database_name = "edgedeck-db"
database_id = "<your-d1-database-id>"
migrations_dir = "migrations"

[[r2_buckets]]
binding = "BUCKET"
bucket_name = "edgedeck-music"
